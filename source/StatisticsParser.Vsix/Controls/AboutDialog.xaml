<Window x:Class="StatisticsParser.Vsix.Controls.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
        Title="About Statistics Parser"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
        Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static vsui:EnvironmentColors.PanelHyperlinkBrushKey}}" />
        </Style>
    </Window.Resources>
    <Grid Margin="24,20,24,16">
        <StackPanel Width="380">
            <Image Source="pack://application:,,,/StatisticsParser.Vsix;component/Images/Brent_Ozar_Unlimited_201609.png"
                   Stretch="None"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16" />
            <TextBlock Text="Statistics Parser"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,2" />
            <TextBlock Text="by Brent Ozar Unlimited"
                       FontSize="12"
                       Margin="0,0,0,12" />
            <TextBlock x:Name="VersionText"
                       FontSize="12"
                       Margin="0,0,0,2" />
            <TextBlock Text="Copyright © 2026 Brent Ozar Unlimited"
                       FontSize="12"
                       Margin="0,0,0,12" />
            <TextBlock Margin="0,0,0,4">
                <Hyperlink NavigateUri="https://www.brentozar.com" RequestNavigate="OnNavigate">www.brentozar.com</Hyperlink>
            </TextBlock>
            <TextBlock Text=""
                       FontSize="12"
                       Margin="0,0,0,12" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyButton"
                        Content="Copy Version Info"
                        Padding="12,4"
                        MinWidth="120"
                        Margin="0,0,8,0"
                        Click="OnCopyDiagnostics" />
                <Button Content="Close"
                        Padding="12,4"
                        MinWidth="80"
                        IsDefault="True"
                        IsCancel="True"
                        Click="OnClose" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
